---
import MainLayout from "../../layouts/MainLayout.astro";
import DirectivaDetalleContenido from "../../componentes/paginas/DirectivaDetalleContenido.astro";
import { directivas } from "../../data/siteData";

export function getStaticPaths() {
  return directivas.map((directiva) => ({
    params: { slug: directiva.slug }
  }));
}

const { slug } = Astro.params;
const directiva = directivas.find((item) => item.slug === slug);

if (!directiva) {
  return Astro.redirect("/directivas/");
}
---

<MainLayout title={`${directiva.titulo} | Escuela Esperanza`}>
  <DirectivaDetalleContenido directiva={directiva} />
</MainLayout>
