---
import Navegacion from "../componentes/sitio/Navegacion.astro";
import PiePagina from "../componentes/pie-pagina/PiePagina.astro";
import ScriptsSitio from "../componentes/sistema/ScriptsSitio.astro";
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Escuela Esperanza",
  description = "Sitio informativo institucional de la Escuela Esperanza."
} = Astro.props;
---

<!DOCTYPE html>
<html lang="es">
  <head>
    <link rel="icon" type="image/x-icon" href="/public/images/Favicon.ico" />
                                                      
<meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Oswald:wght@400;500;600;700&family=Cormorant+Garamond:wght@500;600;700&display=swap"
      rel="stylesheet"
    />
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css"
    />
  </head>
  <body id="top">
    <Navegacion />
    <slot />
    <PiePagina />
    <ScriptsSitio />
  </body>
</html>
