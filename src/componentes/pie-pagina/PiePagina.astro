---
import { contactoEscuela, menu } from "../../data/siteData";

const escuelaMenu = menu.find((item) => item.label === "Nuestra Escuela")?.children ?? [];
const comunidadMenu = menu.find((item) => item.label === "Comunidad escolar")?.children ?? [];
const documentosMenu = menu.find((item) => item.label === "Documentos oficiales");
const enlacesSecciones = menu.filter(
  (item) =>
    !["Inicio", "Nuestra Escuela", "Comunidad escolar", "Documentos oficiales"].includes(
      item.label
    )
);
---

<footer class="site-footer">
  <div class="footer-top-line"></div>

  <div class="footer-main">
    <div class="footer-brand-block">
      <div class="footer-logo-wrap">
        <img src="/images/logo-escuela.png" alt="Logo Escuela Esperanza" />
        <div class="footer-brand-text">
          <h3>Escuela Esperanza</h3>
        </div>
      </div>
    </div>

    <div class="footer-column">
      <h4>Nuestra Escuela</h4>
      {escuelaMenu.map((item) => <a href={item.href}>{item.label}</a>)}
    </div>

    <div class="footer-column">
      <h4>Comunidad escolar</h4>
      {comunidadMenu.map((item) => <a href={item.href}>{item.label}</a>)}
    </div>

    <div class="footer-column">
      <h4>Secciones</h4>
      {enlacesSecciones.map((item) => <a href={item.href}>{item.label}</a>)}
      <a href={documentosMenu?.href ?? "/documentos-oficiales/"}>Documentos oficiales</a>
    </div>

    <div class="footer-column">
      <h4>Contacto</h4>
      <p><i class="fa-solid fa-location-dot"></i> {contactoEscuela.direccion}</p>
      <p><i class="fa-solid fa-phone"></i> {contactoEscuela.telefono}</p>
      <p><i class="fa-solid fa-envelope"></i> {contactoEscuela.correo}</p>
      <p><i class="fa-regular fa-clock"></i> Lunes a jueves: 08:30 - 17:30 hrs</p>
      <p><i class="fa-regular fa-clock"></i> Viernes: 08:30 - 14:00 hrs</p>
    </div>
  </div>

  <div class="footer-bottom">
    <p>Escuela Esperanza 2026 © </p>
   

    <a href="#top" class="back-to-top" aria-label="Volver arriba">
      <i class="fa-solid fa-chevron-up"></i>
    </a>
  </div>
</footer>
