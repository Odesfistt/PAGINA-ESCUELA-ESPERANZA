---
import { menu } from "../../data/siteData";
import { rutas } from "../../lib/rutas";
---

<header class="desktop-header">
  <div class="top-header">
    <div class="brand-area">
      <div class="brand-wrap">
        <img src="/images/logo-escuela.png" alt="Logo Escuela Esperanza" />
        <div class="brand-text">
          <span class="line1">Escuela</span>
          <span class="line2">Esperanza</span>
        </div>
      </div>
    </div>

    <nav class="nav-area" aria-label="Principal">
      <div class="nav-content">
        <ul class="menu">
          {menu.map((item) => (
            <li class:list={["menu-item", { "menu-item--dropdown": item.children }]}>
              <a href={item.href}>
                {item.label}
                {item.children && <i class="fa-solid fa-chevron-down"></i>}
              </a>

              {item.children && (
                <ul class="submenu">
                  {item.children.map((child) => (
                    <li>
                      <a
                        href={child.href}
                        target={child.external ? "_blank" : undefined}
                        rel={child.external ? "noopener noreferrer" : undefined}
                      >
                        {child.label}
                      </a>
                    </li>
                  ))}
                </ul>
              )}
            </li>
          ))}
        </ul>

      </div>
    </nav>
  </div>

  <section class="contact-bar">
    <div class="contact-content">
      <div class="contact-item">
        <i class="fa-solid fa-paper-plane"></i>
        <span>(71) 224 4049</span>
      </div>

      <div class="contact-item">
        <i class="fa-solid fa-envelope"></i>
        <span>escuelaesperanza@daemtalca.cl</span>
      </div>

      <div class="contact-item">
        <i class="fa-regular fa-clock"></i>
        <span>Lunes a jueves: 08:30 - 17:00 hrs · Viernes: 08:30 - 14:00 hrs</span>
      </div>
    </div>
  </section>
</header>

<header class="mobile-header">
  <div class="mobile-topbar">
    <button class="mobile-icon-btn" id="openMenuBtn" aria-label="Abrir menu" type="button">
      <i class="fa-solid fa-bars"></i>
    </button>

    <a href={rutas.inicio} class="mobile-brand">
      <img src="/images/logo-escuela.png" alt="Logo Escuela Esperanza" />
      <span>Escuela Esperanza</span>
    </a>

    <span class="mobile-icon-spacer" aria-hidden="true"></span>
  </div>
</header>

<div class="scroll-header" id="scrollHeader">
  <div class="scroll-header-container scroll-header-desktop">
    <a href={rutas.inicio} class="scroll-brand">
      <img src="/images/logo-escuela.png" alt="Logo Escuela Esperanza" />
      <span>Escuela Esperanza</span>
    </a>

    <nav class="scroll-nav" aria-label="Principal fija">
      {menu.map((item) => (
        <div class:list={["scroll-nav-item", { "scroll-nav-item--dropdown": item.children }]}>
          <a href={item.href}>
            {item.label}
            {item.children && <i class="fa-solid fa-chevron-down"></i>}
          </a>

          {item.children && (
            <div class="scroll-submenu">
              {item.children.map((child) => (
                <a
                  href={child.href}
                  target={child.external ? "_blank" : undefined}
                  rel={child.external ? "noopener noreferrer" : undefined}
                >
                  {child.label}
                </a>
              ))}
            </div>
          )}
        </div>
      ))}
    </nav>

  </div>

  <div class="scroll-header-container-mobile">
    <button
      class="scroll-mobile-btn"
      id="openMenuBtnScroll"
      aria-label="Abrir menu"
      type="button"
    >
      <i class="fa-solid fa-bars"></i>
    </button>

    <a href={rutas.inicio} class="scroll-mobile-brand">
      <img src="/images/logo-escuela.png" alt="Logo Escuela Esperanza" />
      <span>Escuela Esperanza</span>
    </a>

    <span class="scroll-mobile-spacer" aria-hidden="true"></span>
  </div>
</div>

<aside class="mobile-menu-overlay" id="mobileOverlay"></aside>

<aside class="mobile-menu" id="mobileMenu">
  <div class="mobile-menu-header">
    <div class="mobile-menu-logo">
      <img src="/images/logo-escuela.png" alt="Logo de Escuela Esperanza" />
    </div>

    <button class="close-menu-btn" id="closeMenuBtn" aria-label="Cerrar menu" type="button">
      <i class="fa-solid fa-xmark"></i>
    </button>
  </div>

  <nav class="mobile-menu-nav" aria-label="Menu movil">
    {menu.map((item) => (
      item.children ? (
        <details class="mobile-menu-group">
          <summary>{item.label}</summary>
          <div class="mobile-submenu">
            {item.children.map((child) => (
              <a
                href={child.href}
                target={child.external ? "_blank" : undefined}
                rel={child.external ? "noopener noreferrer" : undefined}
              >
                {child.label}
              </a>
            ))}
          </div>
        </details>
      ) : (
        <a href={item.href}>{item.label}</a>
      )
    ))}
    <a href={rutas.admin}>ADMINISTRADOR</a>
  </nav>
</aside>
