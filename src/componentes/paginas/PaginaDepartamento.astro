---
import AccionesPaginaInterna from "./AccionesPaginaInterna.astro";

interface Props {
  kicker: string;
  titulo: string;
  imagen: string;
  icono: string;
  parrafos: string[];
  tarjetas?: {
    titulo: string;
    icono: string;
    texto: string;
  }[];
  variante?: "orientacion" | "informatica";
}

const { kicker, titulo, imagen, icono, parrafos, variante = "orientacion" } = Astro.props;
const seccionesApoyo = [
  { titulo: "Espacio de apoyo", icono: "fa-hand-holding-heart", texto: "Ayuda tecnológica y orientación digital para estudiantes y docentes." },
  { titulo: "Acompañamiento", icono: "fa-people-group", texto: "Apoyo constante en el aprendizaje de herramientas informáticas y proyectos tecnológicos." },
  { titulo: "Educación digital", icono: "fa-clipboard-list", texto: "Promueve el uso responsable de la tecnología, y la innovación educativa." }
];
---

<main class="internal-page">
  <section class="internal-hero">
    <div class="internal-hero-content">
      <span class="internal-kicker">{kicker}</span>
      <h1>{titulo}</h1>
      <AccionesPaginaInterna sectionHref="/" sectionLabel="Inicio" sectionIcon="fa-house" />
    </div>
  </section>

  <section class:list={["department-page-section", `department-page-section--${variante}`]}>
    <div class:list={["department-page-container", `department-page-container--${variante}`]}>
      <div class="department-page-main">
        <div class="department-page-media">
          <img src={imagen} alt={titulo} />
        </div>

        <div class="department-page-content">
          <span><i class={`fa-solid ${icono}`}></i></span>
          <h2>{titulo}</h2>
          {parrafos.map((parrafo) => (
            <p>{parrafo}</p>
          ))}
        </div>
      </div>

      <div class="department-support-grid">
        {seccionesApoyo.map((seccion) => (
          <article class="department-support-card">
            <span><i class={`fa-solid ${seccion.icono}`}></i></span>
            <h3>{seccion.titulo}</h3>
            <p>{seccion.texto}</p>
          </article>
        ))}
      </div>
    </div>
  </section>
</main>
