---
import { directivas } from "../../data/siteData";
import AccionesPaginaInterna from "./AccionesPaginaInterna.astro";
import NavegacionSecciones from "./NavegacionSecciones.astro";

interface Props {
  directiva: (typeof directivas)[number];
}

const { directiva } = Astro.props;
const integrantes = directiva.integrantes ?? [];
const secciones = directiva.secciones ?? [{ titulo: directiva.titulo, texto: directiva.descripcion }];

const obtenerParrafos = (texto: string | string[]) => Array.isArray(texto) ? texto : [texto];
---

<main class="internal-page">
  <section class="internal-hero">
    <div class="internal-hero-content">
      <span class="internal-kicker">Comunidad escolar</span>
      <h1>{directiva.titulo}</h1>
      <AccionesPaginaInterna
        sectionHref="/directivas/"
        sectionLabel="Directivas"
        sectionIcon="fa-table-cells-large"
      />
    </div>
  </section>

  <section class="directory-detail-section">
    <div class="directory-detail-container">
      <NavegacionSecciones
        items={directivas}
        activeSlug={directiva.slug}
        label="Navegar entre directivas"
      />

      {
        integrantes.length > 0 ? (
          <div class="directory-members-grid">
            {integrantes.map((integrante) => (
              <article class="directory-member-card">
                <div class="directory-member-photo">
                  <img src={integrante.imagen} alt={integrante.nombre} />
                </div>
                <h2>
                  {integrante.nombre}
                  <span>({integrante.cargo})</span>
                </h2>
                {obtenerParrafos(integrante.descripcion).map((parrafo) => (
                  <p>{parrafo}</p>
                ))}
              </article>
            ))}
          </div>
        ) : (
          <div class="profiles-empty">
            <p>Los perfiles de esta directiva se publicaran proximamente.</p>
          </div>
        )
      }

      <section class="about-info-block directory-description-block">
        <h2>{directiva.titulo}</h2>

        <div class="directory-info-sections">
          {secciones.map((seccion) => (
            <article class="directory-info-section">
              <h3>{seccion.titulo}</h3>
              {seccion.texto.map((parrafo) => (
                <p>{parrafo}</p>
              ))}
            </article>
          ))}
        </div>
      </section>
    </div>
  </section>
</main>
