---
import { talleres } from "../../data/siteData";
import { rutas } from "../../lib/rutas";
import AccionesPaginaInterna from "./AccionesPaginaInterna.astro";
import NavegacionSecciones from "./NavegacionSecciones.astro";

interface Props {
  taller: (typeof talleres)[number];
}

const { taller } = Astro.props;
const usaTextoContinuado = taller.slug === "programacion-robotica";
const sinInformacion = "sinInformacion" in taller && taller.sinInformacion;
const descripcionLateral = usaTextoContinuado ? taller.descripcion.slice(0, 2) : taller.descripcion;
const descripcionInferior = usaTextoContinuado ? taller.descripcion.slice(2) : [];
---

<main class="internal-page">
  <section class="internal-hero">
    <div class="internal-hero-content">
      <span class="internal-kicker">Talleres</span>
      <h1>{taller.titulo}</h1>
      <AccionesPaginaInterna
        sectionHref="/talleres/"
        sectionLabel="Talleres"
        sectionIcon="fa-table-cells-large"
      />
    </div>
  </section>

  <section class="about-page-section">
    <div class="about-page-detail about-page-detail--compact">
      <NavegacionSecciones
        items={talleres}
        activeSlug={taller.slug}
        label="Navegar entre talleres"
      />

      <section class="about-info-block">
        <div class="workshop-detail-layout">
          <img src={taller.imagen} alt={taller.titulo} />

          <div>
            {taller.ciclo && <span class="workshop-detail-cycle">{taller.ciclo}</span>}
            <h2>{taller.titulo}</h2>
            {descripcionLateral.map((parrafo) => (
              <p>{parrafo}</p>
            ))}

            {sinInformacion && (
              <a class="workshop-contact-button" href={rutas.contacto}>
                <i class="fa-solid fa-envelope"></i>
                Contacto
              </a>
            )}
          </div>

          {descripcionInferior.length > 0 && (
            <div class="workshop-detail-continuation">
              {descripcionInferior.map((parrafo) => (
                <p>{parrafo}</p>
              ))}
            </div>
          )}
        </div>
      </section>

      {taller.aspectosClaves && (
        <section class="workshop-key-section">
          <div class="pie-staff-heading">
            <span>Aspectos Claves</span>
            <h2>{taller.titulo}</h2>
          </div>

          <div class="workshop-key-grid">
            {taller.aspectosClaves.map((aspecto) => (
              <article class="workshop-key-card">
                <h3>{aspecto.titulo}</h3>
                <p>{aspecto.texto}</p>
              </article>
            ))}
          </div>
        </section>
      )}
    </div>
  </section>
</main>
