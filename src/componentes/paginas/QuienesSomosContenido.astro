---
import { quienesSomosDetalle } from "../../data/siteData";
import AccionesPaginaInterna from "./AccionesPaginaInterna.astro";
---

<main class="internal-page">
  <section class="internal-hero">
    <div class="internal-hero-content">
      <span class="internal-kicker">Quienes somos</span>
      <h1>{quienesSomosDetalle.titulo}</h1>
      <AccionesPaginaInterna sectionHref="/" sectionLabel="Inicio" sectionIcon="fa-house" />
    </div>
  </section>

  <section class="about-page-section">
    <div class="about-school-layout">
      <div class="about-school-copy">
        <span>Identidad institucional</span>
        <h2>Una comunidad educativa en construccion</h2>
        <div class="about-school-text">
          {quienesSomosDetalle.texto.map((parrafo) => (
            <p>{parrafo}</p>
          ))}
        </div>

        <div class="about-school-highlights" aria-label="Aspectos institucionales">
          <div>
            <strong>Historia</strong>
            <small>Contenido pendiente</small>
          </div>
          <div>
            <strong>Sello educativo</strong>
            <small>Contenido pendiente</small>
          </div>
          <div>
            <strong>Comunidad</strong>
            <small>Contenido pendiente</small>
          </div>
        </div>
      </div>

      <div class="about-school-media">
        <img src={quienesSomosDetalle.imagen} alt="Escuela Esperanza" />
        <div class="about-school-note">
          <i class="fa-solid fa-school"></i>
          <p>Este espacio esta preparado para recibir la informacion oficial de la escuela.</p>
        </div>
      </div>
    </div>
  </section>
</main>
