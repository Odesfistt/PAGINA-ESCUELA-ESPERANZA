---
import { quienesSomosDetalle } from "../../data/siteData";
import AccionesPaginaInterna from "./AccionesPaginaInterna.astro";
---

<main class="internal-page">
  <section class="internal-hero">
    <div class="internal-hero-content">
      <span class="internal-kicker">Quienes somos</span>
      <h1>{quienesSomosDetalle.titulo}</h1>
      <AccionesPaginaInterna sectionHref="/" sectionLabel="Inicio" sectionIcon="fa-house" />
    </div>
  </section>

  <section class="about-page-section">
    <div class="about-page-container about-page-container--flow">
      <div class="about-page-content about-page-content--framed about-page-content--flow">
        <h2>Quienes somos</h2>

        <div class="about-flow-top">
          <div class="about-flow-copy">
            {quienesSomosDetalle.texto.map((parrafo) => (
              <p>{parrafo}</p>
            ))}
          </div>

          <img src={quienesSomosDetalle.imagen} alt="Escuela Esperanza" />
        </div>
      </div>
    </div>
  </section>
</main>
