---
import { documentosOficiales } from "../../data/siteData";
import AccionesPaginaInterna from "./AccionesPaginaInterna.astro";

const descripcionDocumentos =
  "En esta seccion se reunen los documentos oficiales disponibles para consulta y descarga de la comunidad educativa.";
---

<main class="internal-page">
  <section class="internal-hero">
    <div class="internal-hero-content">
      <span class="internal-kicker">Escuela</span>
      <h1>Documentos oficiales</h1>
      <AccionesPaginaInterna sectionHref="/" sectionLabel="Inicio" sectionIcon="fa-house" />
    </div>
  </section>

  <section class="about-page-section">
    <div class="about-page-detail about-page-detail--compact">
      <section class="workshops-intro-panel official-documents-intro-panel">
        <div>
          <span>Archivo institucional</span>
          <h2>Material disponible para la comunidad</h2>
        </div>
        <p>{descripcionDocumentos}</p>
      </section>

      {
        documentosOficiales.length > 0 ? (
          <section class="official-documents-grid" aria-label="Documentos oficiales">
            {documentosOficiales.map((documento) => (
              <a
                class="official-document-card"
                href={documento.href}
                target="_blank"
                rel="noopener noreferrer"
              >
                <span>
                  <i class="fa-solid fa-file-pdf"></i>
                </span>
                <h2>{documento.titulo}</h2>
                <p>Descargar documento oficial en PDF.</p>
              </a>
            ))}
          </section>
        ) : (
          <div class="official-documents-empty official-documents-empty--page">
            <p>Los documentos oficiales se publicaran proximamente.</p>
          </div>
        )
      }
    </div>
  </section>
</main>
