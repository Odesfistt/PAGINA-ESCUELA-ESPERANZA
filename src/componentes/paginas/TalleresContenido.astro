---
import { talleres } from "../../data/siteData";
import AccionesPaginaInterna from "./AccionesPaginaInterna.astro";
---

<main class="internal-page">
  <section class="internal-hero">
    <div class="internal-hero-content">
      <span class="internal-kicker">Actividades escolares</span>
      <h1>Talleres</h1>
      <AccionesPaginaInterna sectionHref="/" sectionLabel="Inicio" sectionIcon="fa-house" />
    </div>
  </section>

  <section class="about-page-section">
    <div class="about-page-detail about-page-detail--compact">
      <section class="workshops-intro-panel">
        <div>
          <span>Talleres escolares</span>
          <h2>Actividades disponibles</h2>
        </div>
        <p>Escuela Esperanza Escuela Esperanza Escuela Esperanza Escuela Esperanza.</p>
      </section>

      <div class="workshop-grid">
        {talleres.map((taller) => (
          <a href={taller.href} class="workshop-card workshop-card--link">
            <img src={taller.imagen} alt={taller.titulo} />
            <h2>{taller.titulo}</h2>
            <p>{taller.descripcion[0]}</p>
            <i class="fa-solid fa-arrow-right"></i>
          </a>
        ))}
      </div>
    </div>
  </section>
</main>
