---
import {
  directivas,
  documentosOficiales,
  instagramInicio,
  talleres
} from "../../data/siteData";
import { rutas } from "../../lib/rutas";
---

<section class="home-directories-section">
  <div class="home-directories-container">
    <div class="home-section-heading">
      <span>Comunidad</span>
      <h2>Directivas</h2>
    </div>

    <div class="home-directories-grid">
      {directivas.map((directiva) => (
        <a href={directiva.href} class="home-directory-card">
          <h3>{directiva.titulo}</h3>
          <i class="fa-solid fa-arrow-right"></i>
        </a>
      ))}
    </div>
  </div>
</section>

<section class="home-sections-section">
  <div class="home-sections-container">
    <div class="home-section-heading">
      <span>Escuela</span>
      <h2>Documentos oficiales</h2>
    </div>

    {
      documentosOficiales.length > 0 ? (
        <div class="institutional-list">
          {documentosOficiales.map((seccion) => (
            <a
              href={seccion.href}
              class="institutional-row"
              target="_blank"
              rel="noopener noreferrer"
            >
              <h3>{seccion.titulo}</h3>
              <i class="fa-solid fa-file-pdf"></i>
            </a>
          ))}
        </div>
      ) : (
        <div class="official-documents-empty">
          <p>Los documentos oficiales se publicaran proximamente.</p>
        </div>
      )
    }
  </div>
</section>

<section class="home-workshops-section">
  <div class="home-workshops-container">
    <div class="home-section-heading home-section-heading--light">
      <span>Talleres</span>
      <h2>Talleres escolares</h2>
    </div>

    <div class="home-workshops-strip">
      {talleres.map((taller) => (
        <a href={taller.href} class="home-workshop-pill">{taller.titulo}</a>
      ))}
    </div>
  </div>
</section>

<section class="home-instagram-section">
  <a
    href={instagramInicio.href}
    class="home-instagram-frame"
    target="_blank"
    rel="noopener noreferrer"
  >
    <div class="home-instagram-topbar">
      <span></span>
      <span></span>
      <span></span>
    </div>

    <div class="home-instagram-profile">
      <img src="/images/logo-escuela.png" alt="Logo Escuela Esperanza" />

      <div class="home-instagram-profile-info">
        <div class="home-instagram-profile-header">
          <h2>{instagramInicio.cuenta}</h2>
          <span>
            <i class="fa-brands fa-instagram"></i>
            Instagram
          </span>
        </div>

        <div class="home-instagram-stats">
          <strong>Publicaciones</strong>
          <strong>Comunidad</strong>
          <strong>Talca</strong>
        </div>

        <h3>{instagramInicio.nombre}</h3>
        <p>Perfil oficial de Instagram</p>
      </div>
    </div>

    <div class="home-instagram-tabs">
      <span><i class="fa-solid fa-table-cells"></i> Publicaciones</span>
      <span><i class="fa-solid fa-play"></i> Videos</span>
    </div>

    <div class="home-instagram-grid">
      {instagramInicio.publicaciones.map((imagen) => (
        <div class="home-instagram-post">
          <img src={imagen} alt="Publicacion de Instagram de Escuela Esperanza" />
          <div class="home-instagram-post-overlay">
            <i class="fa-brands fa-instagram"></i>
          </div>
        </div>
      ))}
    </div>

    <div class="home-instagram-cta">
      <span>Ver perfil en Instagram</span>
      <i class="fa-solid fa-arrow-up-right-from-square"></i>
    </div>
  </a>
</section>
